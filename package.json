{
  "name": "qoowork-monorepo",
  "private": true,
  "description": "qoowork AI 办公平台 - 客户端、云端服务、IDE 插件",
  "workspaces": [
    "client",
    "cloud",
    "ide-plugin"
  ],
  "scripts": {
    "client:dev": "npm run electron:dev --workspace=client",
    "client:dev:openclaw": "npm run electron:dev:openclaw --workspace=client",
    "client:build": "npm run build --workspace=client",
    "client:dist:win": "npm run dist:win --workspace=client",
    "client:dist:mac": "npm run dist:mac --workspace=client",
    "client:dist:linux": "npm run dist:linux --workspace=client",
    "client:test": "npm test --workspace=client",
    "lint": "npm run lint --workspace=client"
  }
}
